{
    "inventory": {
        "name": "Inventaire du service EC2",
        "providers": {
            "aws" : {
                "filters": {
                    "profiles": ["developpement", "recette", "production", "shared", "network", "tools", "securite", "vmc"],
                    "regions": ["us-east-1", "eu-west-3", "eu-west-1"],
                    "services": ["ec2"]
                },
                "services": {
                    "ec2": {
                        "filters": {
                            "resource_types": [
                                "instance", 
                                "security_group"
                            ]
                        }
                    }
                }
            }
        },
        "debug_mode": "DEBUG"
    }
}
