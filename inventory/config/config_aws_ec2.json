{
    "inventory": {
        "name": "Inventaire du service EC2",
        "providers": {
            "aws" : {
                "filters": {
                    "profiles": ["developpement", "recette", "production", "shared", "network", "tools", "securite", "vmc"],
                    "regions": ["eu-west-3"],
                    "services": ["ec2"]
                },
                "services": {
                    "ec2": {
                        "filters": {
                            "resource_types": [
                                "instance" 
                            ]
                        }
                    }
                }
            }
        },
        "#debug_mode": "DEBUG",
        "output": {
            "mode": "file",
            "format": "json",
            "output_file": "./inventory_ec2.json"
        }
    }
}
