{
    "inventory": {
        "name": "Inventaire du service EC2",
        "providers": {
            "aws" : {
                "filters": {
                    "profiles": ["developpement"],
                    "regions": ["eu-west-3"],
                    "services": ["ec2"]
                },
                "services": {
                    "ec2": {
                        "filters": {
                            "resource_types": [
                                "instance" 
                            ]
                        }
                    }
                }
            }
        },
        "#debug_mode": "DEBUG",
        "output": {
            "mode": "file",
            "format": "json",
            "output_file": "./inventory_ec2.json",
            "#selected_fields": {
                "Id": "Id",
                "Name": "Name",
                "Description": "Description",
                "State": "State",
                "PrivateIpAddress": "PrivateIpAddress"
            }
        }
    }
}
