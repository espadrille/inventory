{
    "inventory": {
        "name": "Inventaire du service EC2",
        "providers": {
            "aws" : {
                "filters": {
                    "profiles": [
                        "citrix",
                        "ddfbackend",
                        "ddfdatalab_developpement",
                        "ddfdatalab_production",
                        "ddfdataplatform_developpement",
                        "ddfdataplatform_production",
                        "ddfdataplatform_staging",
                        "ddfmlplatform_developpement",
                        "ddfmlplatform_production",
                        "ddfmlplatform_staging",
                        "developpement", 
                        "network", 
                        "ot",
                        "production", 
                        "recette", 
                        "securite", 
                        "shared", 
                        "tools",
                        "vmc"
                    ],
                    "regions": ["eu-west-1", "eu-west-3"],
                    "services": ["ec2"]
                },
                "services": {
                    "ec2": {
                        "filters": {
                            "resource_types": [
                                "instance"
                            ]
                        }
                    }
                }
            }
        },
        "debug_mode": "DEBUG",
        "output": {
            "mode": "file",
            "format": "csv",
            "output_file": "./carto_infrastructure_aws_ec2.csv",
            "selected_fields": {
                "Hypervisor": "HYPERVISEUR",
                "VERSION vCENTER": "VERSION vCENTER",
                "Host": "Host",
                "Name": "VM",
                "State": "ETAT",
                "LaunchTime": "DATE_DEMARRAGE_OS",
                "CreationTime": "DATE_CREATION_VM",
                "PlatformDetails": "OS",
                "PrivateDnsName": "DNS",
                "PrivateIpAddress": "IP",
                "Description": "ANNOTATION",
                "BALISES_VEEAM": "BALISES_VEEAM", 
                "BALISES_NETBACKUP": "BALISES_NETBACKUP",
                "Profile": "BALISES_Environnement",
                "Platform": "BALISES_GuestOS",
                "SubnetName_1": "Network #1" ,
                "SubnetName_2": "Network #2" ,
                "SubnetName_3": "Network #3" ,
                "SubnetName_4": "Network #4" ,
                "SubnetName_5": "Network #5" ,
                "SubnetName_6": "Network #6" ,
                "SubnetName_7": "Network #7" ,
                "SubnetName_8": "Network #8"
            },
            "csv_separator": ";",
            "csv_print_header": true
        }
    }
}
