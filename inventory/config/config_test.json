{
    "inventory": {
        "name": "Inventaire du service EC2",
        "providers": {
            "aws" : {
                "filters": {
                    "profiles": ["network"],
                    "regions": ["eu-west-3"],
                    "services": ["ec2"]
                },
                "services": {
                    "ec2": {
                        "filters": {
                            "resource_types": [
                                "instance"
                            ]
                        }
                    }
                }
            }
        },
        "#debug_mode": "DEBUG",
        "output": {
            "mode": "file",
            "format": "json",
            "output_file": "./inventory_test.json",
            "#selected_fields": {
                "Hypervisor": "HYPERVISEUR",
                "VERSION vCENTER": "VERSION vCENTER",
                "Host": "Host",
                "Name": "VM",
                "State": "ETAT",
                "LaunchTime": "DATE_DEMARRAGE_OS",
                "DATE_CREATION_VM": "DATE_CREATION_VM",
                "PlatformDetails": "OS",
                "PrivateDnsName": "DNS",
                "PrivateIpAddress": "IP",
                "Description": "ANNOTATION",
                "BALISES_VEEAM": "BALISES_VEEAM", 
                "BALISES_NETBACKUP": "BALISES_NETBACKUP",
                "BALISES_Environnement": "BALISES_Environnement",
                "BALISES_GuestOS": "BALISES_GuestOS",
                "NetworkInterface_1": "Network #1" ,
                "NetworkInterface_2": "Network #2" ,
                "NetworkInterface_3": "Network #3" ,
                "NetworkInterface_4": "Network #4" ,
                "NetworkInterface_5": "Network #5" ,
                "NetworkInterface_6": "Network #6" ,
                "NetworkInterface_7": "Network #7" ,
                "NetworkInterface_8": "Network #8"
            },
            "csv_separator": ";",
            "csv_print_header": true
        }
    }
}
