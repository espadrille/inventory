{
    "inventory": {
        "name": "Inventaire du service S3",
        "providers": {
            "aws" : {
                "filters": {
                    "profiles": ["developpement", "shared", "vmc"],
                    "services": ["s3"]
                }
            }
        },
        "debug_mode": "DEBUG",
        "output": {
            "mode": "file",
            "format": "csv",
            "output_file": "./inventory_s3.csv",
            "selected_fields": [
                "category",
                "name",
                "description",
                "versioning",
                "profile"
            ],
            "csv_separator": ";",
            "csv_print_header": true
        }
    }
}